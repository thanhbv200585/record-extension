{
  "manifest_version": 3,
  "name": "AutoFlow Recorder",
  "version": "1.7.0",
  "description": "Record and replay user interactions for automated testing.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "debugger",
    "webNavigation"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "file:///*"
      ],
      "js": [
        "scripts/content.js"
      ]
    }
  ]
}